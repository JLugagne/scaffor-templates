// --- Getters ---

func (e *{{ .Entity }}) ID() {{ .Entity }}ID   { return e.id }
func (e *{{ .Entity }}) CreatedAt() time.Time   { return e.createdAt }
func (e *{{ .Entity }}) UpdatedAt() time.Time   { return e.updatedAt }

