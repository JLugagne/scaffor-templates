// {{ .Entity | lower }}Service combines Commands and Queries for handlers that need
// read-before-write (e.g. update: fetch current state, apply patch, save).
// The *app.App passed from the wire file satisfies both interfaces.
type {{ .Entity | lower }}Service interface {
	{{ .Entity | lower }}uc.{{ .Entity }}Commands
	{{ .Entity | lower }}uc.{{ .Entity }}Queries
}

type {{ .Entity | lower }}Handler struct {
	svc       {{ .Entity | lower }}Service
	validator *validator.Validate
}

// {{ .Entity | lower }}ActionRegistrar registers a single action route on the router.
//
// Each file generated by `add_http_action` appends one registrar via init():
//
//	func init() {
//	    {{ .Entity | lower }}CommandsActions = append({{ .Entity | lower }}CommandsActions, func(r *mux.Router, h *{{ .Entity | lower }}Handler) {
//	        r.HandleFunc("/api/v1/.../action", h.action).Methods(http.MethodPost)
//	    })
//	}
//
// Setup{{ .Entity }}Routes iterates this slice — no manual wiring in wire_{{ .Entity | lower }}.go needed.
type {{ .Entity | lower }}ActionRegistrar func(r *mux.Router, h *{{ .Entity | lower }}Handler)

var {{ .Entity | lower }}CommandsActions []{{ .Entity | lower }}ActionRegistrar

// Setup{{ .Entity }}Routes registers HTTP command routes for {{ .Entity }}.
// Called from the composition root (wire_{{ .Entity | lower }}.go).
func Setup{{ .Entity }}Routes(r *mux.Router, svc {{ .Entity | lower }}Service, v *validator.Validate) {
	h := &{{ .Entity | lower }}Handler{svc: svc, validator: v}
	r.HandleFunc("/api/v1/projects/{projectID}/{{ .Entity | lower }}s", h.create).Methods(http.MethodPost)
	{{- if ne .EntityHasActions "true" }}
	r.HandleFunc("/api/v1/projects/{projectID}/{{ .Entity | lower }}s/{id}", h.update).Methods(http.MethodPut)
	r.HandleFunc("/api/v1/projects/{projectID}/{{ .Entity | lower }}s/{id}", h.delete).Methods(http.MethodDelete)
	{{- end }}
	for _, fn := range {{ .Entity | lower }}CommandsActions {
		fn(r, h)
	}
}

func (h *{{ .Entity | lower }}Handler) create(w http.ResponseWriter, r *http.Request) {
	actor, err := shared.ActorFromRequest(r.Context(), r)
	if err != nil {
		shared.WriteErrorJSON(w, http.StatusUnauthorized, "UNAUTHORIZED", err.Error())
		return
	}

	var req v1.Create{{ .Entity }}Request
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		shared.WriteErrorJSON(w, http.StatusBadRequest, "INVALID_JSON", err.Error())
		return
	}
	if err := h.validator.Struct(req); err != nil {
		shared.WriteErrorJSON(w, http.StatusBadRequest, "VALIDATION_FAILED", err.Error())
		return
	}

	_ = actor
	// TODO(scaffolding): convert `req` into the domain-type argument list expected by
	// h.svc.Create{{ .Entity }} (use converters.To{{ .Entity }}Domain), call the usecase
	// with (r.Context(), actor, ...), then encode the response via converters.ToPublic{{ .Entity }}
	// and shared.WriteJSON(w, http.StatusCreated, resp). Map domain errors to HTTP status
	// via shared.WriteDomainError (or equivalent) — never leak raw error strings.
	// Required before any POST {{ .Entity | lower }} test passes — handler currently
	// returns 501 regardless of input.
	w.WriteHeader(http.StatusNotImplemented)
}

