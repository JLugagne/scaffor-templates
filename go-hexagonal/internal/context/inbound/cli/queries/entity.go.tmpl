// Setup{{ .Entity }}Queries registers CLI query sub-commands for {{ .Entity }} under the given root.
// Called from the CLI entry point (cmd/{{ .Context }}-cli/main.go).
func Setup{{ .Entity }}Queries(root *cobra.Command, q {{ .Entity | lower }}uc.{{ .Entity }}Queries) {
	h := &{{ .Entity | lower }}Handler{queries: q}

	group := root.Commands()
	var entityGroup *cobra.Command
	for _, c := range group {
		if c.Use == "{{ .Entity | lower }}" {
			entityGroup = c
			break
		}
	}
	if entityGroup == nil {
		entityGroup = &cobra.Command{
			Use:   "{{ .Entity | lower }}",
			Short: "Manage {{ .Entity | lower }}s",
		}
		root.AddCommand(entityGroup)
	}

	entityGroup.AddCommand(h.getCmd())
	entityGroup.AddCommand(h.listCmd())
}

