package shared

import (
	"encoding/json"
	"fmt"
	"os"
)

// WriteJSON prints a pretty-printed JSON representation of v to stdout.
// CLI handlers use this for consistent machine-readable output.
func WriteJSON(v any) error {
	enc := json.NewEncoder(os.Stdout)
	enc.SetIndent("", "  ")
	return enc.Encode(v)
}

// WriteDeleted prints a short deleted confirmation to stdout.
func WriteDeleted(id string) {
	fmt.Fprintf(os.Stdout, "deleted %s\n", id)
}
