	{{ .Entity | lower }}uc.{{ .Entity }}Commands
	{{ .Entity | lower }}uc.{{ .Entity }}Queries
}

type {{ .Entity | lower }}Handler struct {
	svc {{ .Entity | lower }}Service
}

// Setup{{ .Entity }}Cmds registers CLI command sub-commands for {{ .Entity }} under the given root.
// Called from the CLI entry point (cmd/{{ .Context }}-cli/main.go).
func Setup{{ .Entity }}Cmds(root *cobra.Command, svc {{ .Entity | lower }}Service) {
	h := &{{ .Entity | lower }}Handler{svc: svc}

	group := &cobra.Command{
		Use:   "{{ .Entity | lower }}",
		Short: "Manage {{ .Entity | lower }}s (create, update, delete)",
	}
	group.AddCommand(h.createCmd())
	group.AddCommand(h.updateCmd())
	group.AddCommand(h.deleteCmd())

	root.AddCommand(group)
}

