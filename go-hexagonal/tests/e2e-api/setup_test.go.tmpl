// ─── HTTP test helpers ───────────────────────────────────────────────────────

// Response wraps an HTTP response with convenience methods for assertions.
type Response struct {
	*http.Response
	Body []byte
}

// JSON unmarshals the response body into dest.
func (r *Response) JSON(t *testing.T, dest interface{}) {
	t.Helper()
	require.NoError(t, json.Unmarshal(r.Body, dest))
}

// doRequest executes an HTTP request and returns the response with the body pre-read.
func doRequest(t *testing.T, method, url string, body interface{}) *Response {
	t.Helper()

	var bodyReader io.Reader
	if body != nil {
		b, err := json.Marshal(body)
		require.NoError(t, err)
		bodyReader = bytes.NewReader(b)
	}

	req, err := http.NewRequest(method, url, bodyReader)
	require.NoError(t, err)
	if body != nil {
		req.Header.Set("Content-Type", "application/json")
	}

	resp, err := http.DefaultClient.Do(req)
	require.NoError(t, err)
	defer resp.Body.Close()

	respBody, err := io.ReadAll(resp.Body)
	require.NoError(t, err)

	return &Response{Response: resp, Body: respBody}
}

// doGet sends a GET request.
func doGet(t *testing.T, url string) *Response {
	t.Helper()
	return doRequest(t, http.MethodGet, url, nil)
}

// doPost sends a POST request with a JSON body.
func doPost(t *testing.T, url string, body interface{}) *Response {
	t.Helper()
	return doRequest(t, http.MethodPost, url, body)
}

// doPut sends a PUT request with a JSON body.
func doPut(t *testing.T, url string, body interface{}) *Response {
	t.Helper()
	return doRequest(t, http.MethodPut, url, body)
}

// doPatch sends a PATCH request with a JSON body.
func doPatch(t *testing.T, url string, body interface{}) *Response {
	t.Helper()
	return doRequest(t, http.MethodPatch, url, body)
}

// doDelete sends a DELETE request.
func doDelete(t *testing.T, url string) *Response {
	t.Helper()
	return doRequest(t, http.MethodDelete, url, nil)
}

// url builds a full URL from the test server base and a path.
// Example: url("/api/v1/projects/%s/items/%s", projectID, itemID)
func url(path string, args ...interface{}) string {
	if len(args) > 0 {
		path = fmt.Sprintf(path, args...)
	}
	return testServer.URL + path
}
