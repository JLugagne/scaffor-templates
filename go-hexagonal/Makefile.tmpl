.PHONY: build test test-short lint lint-arch lint-all migrate

build:
	go build ./...

test:
	go test -race ./... -count=1 -v

test-short:
	go test -race ./... -count=1 -short

lint:
	go vet ./...

lint-arch:
	go-arch-lint check

lint-all: lint lint-arch

migrate:
	@echo "Run migrations against local dev database"
